{
  "expo": {
    "name": "ACT",
    "slug": "act",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/act-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "act",
    "splash": {
      "image": "./assets/splash-screen.png",
      "backgroundColor": "#fafafb",
      "imageWidth": 200
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.act"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/act-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.act"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
